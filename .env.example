# DiretorioPeruano (ConectaPerú) - Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git!

# ============================================
# REQUIRED - Clerk Authentication
# Get from: https://dashboard.clerk.com/apps/app_3GVoHO4YI3D66tNLyOlNwdWdNfY
# ============================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# ============================================
# REQUIRED - Neon PostgreSQL Database
# Get from: https://console.neon.tech/projects/
# ============================================
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.region.neon.tech/neondb?sslmode=require

# ============================================
# OPTIONAL - Analytics & Monitoring
# ============================================
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================
# OPTIONAL - Feature Flags
# ============================================
# VITE_ENABLE_BETA_FEATURES=false
# VITE_ENABLE_ANALYTICS=true

# ============================================
# DEVELOPMENT ONLY
# ============================================
# NODE_ENV=development
# VITE_API_URL=http://localhost:3000